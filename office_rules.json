      },
      "archivierung": {
        "basis_ordnername": "archiv",
        "lauf_ordner_suffix": "archiv"
      },
      "dokumente": {
        "basis_pfad": "./testing/documents",
        "dateiname": {
          "prefix": "d",
          "suffix_placeholder": "vn",
          "fallback_name": "unknown-document",
          "max_woerter": 5,
          "schlagwoerter": [
            {
              "name": "contract-rental",
              "hinweise": ["mietvertrag", "rental contract", "lease agreement", "lease contract"]
            },
            {
              "name": "tax-notice",
              "hinweise": ["steuerbescheid", "tax notice", "tax assessment"]
            },
            {
              "name": "insurance-letter",
              "hinweise": ["versicherung", "insurance", "policy", "claims"]
            }
          ]
        }
      },
      "duplicate_handling": {
        "report_folder": "_duplicate_reports",
        "report_extension": ".txt"
      },
      "supplier_cleaning": {
        "remove_suffix_patterns": [
          "\\n[\\w\\W]*",
          "\\\\b(?:elisabethenstr(?:asse)?|bismarckstr(?:asse)?|roetestr(?:asse)?|r\\u00f6testr(?:asse)?)\\\\b.*$",
          "\\\\b(?:strasse|straße|weg|allee|platz)\\\\s+\\d+[a-z]?\\\\b.*$"
        ],
        "supplier_aliases": {
          "ecasypark": "easypark",
          "deine-rechnungsadresse": "dm-drogerie-markt",
          "deine-rechnungsadres": "dm-drogerie-markt"
        }
      }
