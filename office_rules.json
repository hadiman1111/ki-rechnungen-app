{
  "active_preset": "office_default",
  "presets": {
    "office_default": {
      "dateiname_schema": {
        "separator": "_",
        "max_laenge": 50,
        "erweiterung": ".pdf",
        "felder": [
          { "typ": "datum", "quelle": "invoice_date", "format": "jjmmtt", "aktiv": true },
          { "typ": "literal", "wert": "er", "aktiv": true },
          { "typ": "wert", "quelle": "art", "aktiv": true },
          { "typ": "wert", "quelle": "supplier", "aktiv": true },
          { "typ": "wert", "quelle": "amount", "aktiv": true },
          { "typ": "wert", "quelle": "payment_field", "aktiv": true }
        ]
      },
      "invoice_fallbacks": {
        "invoice_date": "unknown-date",
        "supplier": "unknown-supplier",
        "amount": "unknown-amount",
        "konto": null
      },
      "classification": {
        "invoice_keywords": [
          "rechnung",
          "invoice"
        ],
        "document_keywords": [
          "spendenbescheinigung",
          "donation confirmation",
          "donation receipt",
          "contribution statement",
          "tax certificate",
          "transfer proof",
          "payment confirmation",
          "bescheid",
          "steuerbescheid",
          "bestellte artikel",
          "bestellbestätigung",
          "order confirmation"
        ],
        "internal_invoice_keywords": [
          "eigenbeleg",
          "interner beleg",
          "internal form"
        ],
        "invoice_like_indicators": [],
        "invoice_like_threshold": 3
      },
      "routing": {
        "unklar_konto": "unklar",
        "default_art": "private",
        "default_payment_method": "unknown",
        "default_payment_field": "unklar",
        "default_zielordner": "unklar",
        "default_status": "unklar",
        "zielordner": {
          "private": "private",
          "ai": "ai",
          "ep": "ep",
          "unklar": "unklar",
          "amex": "amex"
        },
        "strassen": [
          {
            "key": "roete",
            "art": "private",
            "varianten": [
              "roetestrasse",
              "roete strasse",
              "roete-strasse",
              "rötestrasse",
              "röte strasse",
              "rotestrasse",
              "rötestr",
              "roetestr",
              "rötestr.",
              "roetestr."
            ],
            "fuzzy_threshold": 0.84
          },
          {
            "key": "bismarck",
            "art": "ai",
            "varianten": [
              "bismarckstrasse",
              "bismarck strasse",
              "bismarck-strasse",
              "bismarckstraße"
            ],
            "fuzzy_threshold": 0.84
          }
        ],
        "prioritaetsregeln": [
          {
            "name": "roete-private-address",
            "text_all": [],
            "text_any": [],
            "provider_any": [],
            "street_any": ["roete"],
            "text_none_any": ["somaa"],
            "require_no_clear_payment": false,
            "zielordner": "private",
            "art": "private",
            "status": "processed"
          }
        ],
        "business_context_rules": [
          {
            "name": "somaa-event-production",
            "text_all": ["somaa", "event"],
            "text_any": ["production", "produktion"],
            "match_source": "raw_text",
            "art": "ep"
          },
          {
            "name": "somaa-architektur-innenarchitektur",
            "text_all": ["somaa"],
            "text_any": ["architektur", "innenarchitektur", "architecture", "interior"],
            "art": "ai"
          },
          {
            "name": "somaa-unspecified",
            "text_any": ["somaa"],
            "art": "ai"
          }
        ],
        "payment_detection_rules": [
          {
            "name": "explicit-amex",
            "text_any": [
              "american express",
              "abbuchung von amex",
              "american express business",
              "american express monatsabrechnung"
            ],
            "payment_method": "amex",
            "explicit": true
          },
          {
            "name": "explicit-paypal",
            "text_any": ["paypal", "pay pal"],
            "payment_method": "paypal",
            "explicit": true
          },
          {
            "name": "explicit-cash",
            "text_any": ["bar bezahlt", "barzahlung", "bargeld", "cash", "cash payment"],
            "payment_method": "bar",
            "explicit": true
          },
          {
            "name": "explicit-direct-debit",
            "text_any": [
              "lastschrift",
              "sepa lastschrift",
              "sepa-lastschrift",
              "direct debit",
              "prenotification",
              "wird abgebucht",
              "von ihrem konto abgebucht",
              "konto abgebucht",
              "bankeinzug"
            ],
            "payment_method": "transfer",
            "explicit": true
          },
          {
            "name": "iban-bic-direct-debit",
            "text_any": ["iban", "bic"],
            "payment_method": "transfer",
            "explicit": true
          },
          {
            "name": "iban-bic-direct-debit-wording",
            "text_all": ["iban", "bic"],
            "text_any": ["lastschrift", "prenotification", "wird abgebucht", "von ihrem konto abgebucht", "bankeinzug"],
            "payment_method": "transfer",
            "explicit": true
          },
          {
            "name": "explicit-transfer",
            "text_any": ["ueberweisung", "überweisung", "bank transfer", "sepa", "iban", "bic"],
            "payment_method": "transfer",
            "explicit": true
          },
          {
            "name": "explicit-ec-card",
            "text_any": ["ec", "ec-karte", "debit card", "card payment", "karte", "visa", "mastercard", "c24"],
            "payment_method": "card",
            "explicit": true
          },
          {
            "name": "cursor-anysphere-amex",
            "text_any": [
              "anysphere",
              "cursor pro",
              "cursor usage",
              "hi@cursor.com",
              "hi cursor com",
              "cursor.com"
            ],
            "payment_method": "amex",
            "explicit": true
          },
          {
            "name": "somaa-default-bank",
            "text_any": ["somaa"],
            "payment_method": "transfer",
            "explicit": false
          }
        ],
        "final_assignment_rules": [
          {
            "name": "amex-account-route",
            "account_payment_field_any": ["amex"],
            "use_account_art": false,
            "use_account_konto": false,
            "use_account_payment_field": false,
            "output_konto": null,
            "output_payment_field": "amex"
          },
          {
            "name": "amex-payment-detected",
            "payment_method_any": ["amex"],
            "use_account_art": false,
            "use_account_konto": false,
            "use_account_payment_field": false,
            "output_konto": null,
            "output_payment_field": "amex"
          },
          {
            "name": "ep-private-card-preserve-category",
            "art_any": ["ep"],
            "account_payment_field_any": ["private"],
            "use_account_art": false,
            "use_account_konto": false,
            "use_account_payment_field": false,
            "output_konto": null,
            "output_payment_field": "private"
          },
          {
            "name": "ai-private-card-preserve-category",
            "art_any": ["ai"],
            "account_payment_field_any": ["private"],
            "use_account_art": false,
            "use_account_konto": false,
            "use_account_payment_field": false,
            "output_konto": null,
            "output_payment_field": "unklar"
          },
          {
            "name": "use-detected-account-output",
            "account_payment_field_any": ["vobaai", "vobaep", "private"],
            "use_account_art": true,
            "use_account_konto": true,
            "use_account_payment_field": true
          },
          {
            "name": "explicit-paypal",
            "payment_method_any": ["paypal"],
            "output_payment_field": "paypal-unklar",
            "output_konto": null
          },
          {
            "name": "explicit-bar",
            "payment_method_any": ["bar"],
            "output_payment_field": "bar",
            "output_konto": null
          },
          {
            "name": "transfer-ai",
            "payment_method_any": ["transfer", "card"],
            "art_any": ["ai"],
            "output_konto": "vobaai",
            "output_payment_field": "vobaai"
          },
          {
            "name": "transfer-ep",
            "payment_method_any": ["transfer", "card"],
            "art_any": ["ep"],
            "output_konto": "vobaep",
            "output_payment_field": "vobaep"
          },
          {
            "name": "somaa-unclear-payment",
            "art_any": ["ai", "ep"],
            "output_payment_field": "unklar",
            "output_konto": null
          },
          {
            "name": "ultimate-fallback",
            "output_payment_field": "unklar",
            "output_konto": null
          }
        ],
        "output_route_rules": [
          {
            "name": "amex-to-amex",
            "payment_field_any": ["amex"],
            "zielordner": "amex",
            "status": "processed"
          },
          {
            "name": "vobaai-to-ai",
            "payment_field_any": ["vobaai"],
            "zielordner": "ai",
            "status": "processed"
          },
          {
            "name": "vobaep-to-ep",
            "payment_field_any": ["vobaep"],
            "zielordner": "ep",
            "status": "processed"
          },
          {
            "name": "private-keep-folder-despite-unclear-attributes",
            "art_any": ["private"],
            "payment_field_any": ["unklar"],
            "zielordner": "private",
            "status": "processed"
          },
          {
            "name": "unklar-to-unklar",
            "payment_field_any": ["unklar", "paypal-unklar"],
            "zielordner": "unklar",
            "status": "unklar"
          },
          {
            "name": "ai-to-ai",
            "art_any": ["ai"],
            "zielordner": "ai",
            "status": "processed"
          },
          {
            "name": "ep-to-ep",
            "art_any": ["ep"],
            "zielordner": "ep",
            "status": "processed"
          },
          {
            "name": "private-to-private",
            "art_any": ["private"],
            "zielordner": "private",
            "status": "processed"
          }
        ],
