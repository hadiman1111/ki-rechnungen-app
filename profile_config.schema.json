{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "profile_config.schema.json",
  "title": "ProfileConfig",
  "description": "UI-orientiertes Nutzerprofil für die Rechnungsverarbeitung. Wird künftig durch einen Profile Compiler in office_rules.json übersetzt. Nutzer sehen keine Regex, keine Regelketten, keine technischen Flags.",
  "type": "object",
  "required": ["schema_version", "profile_name", "categories", "folders", "account_card_profiles", "address_profiles", "naming_profile", "review_policy"],
  "additionalProperties": false,
  "properties": {

    "schema_version": {
      "type": "string",
      "minLength": 1,
      "description": "Version des Profil-Schemas. Ermöglicht spätere Migration.",
      "examples": ["1.0"]
    },

    "profile_name": {
      "type": "string",
      "minLength": 1,
      "description": "Nutzerfreundlicher Name dieses Profils.",
      "examples": ["Hadi Standardprofil"]
    },

    "description": {
      "type": "string",
      "description": "Optionale Beschreibung des Profils."
    },

    "categories": {
      "type": "array",
      "description": "Bekannte Rechnungskategorien. UI kann Labels anzeigen.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Category" }
    },

    "folders": {
      "type": "array",
      "description": "Zielordner-Definitionen. Jeder Ordner hat eine ID, ein Label und einen Ordnernamen.",
      "minItems": 1,
      "items": { "$ref": "#/$defs/Folder" }
    },

    "account_card_profiles": {
      "type": "array",
      "description": "Karten, Konten und IBAN-Profile. Nutzer pflegen Endungen und Anbieterhinweise.",
      "items": { "$ref": "#/$defs/AccountCardProfile" }
    },

    "address_profiles": {
      "type": "array",
      "description": "Adressen, die einer Kategorie zugeordnet werden. Varianten werden vom Compiler generiert.",
      "items": { "$ref": "#/$defs/AddressProfile" }
    },

    "naming_profile": {
      "$ref": "#/$defs/NamingProfile",
      "description": "Dateinamenstruktur und Fallback-Werte."
    },

    "review_policy": {
      "$ref": "#/$defs/ReviewPolicy",
      "description": "Verhalten bei unklaren oder widersprüchlichen Dokumenten."
    },

    "vendor_profiles": {
      "type": "array",
      "description": "Bekannte Lieferanten mit Zahlungszuordnung. Optionaler Bereich, in Version 1.0 locker modelliert.",
      "items": { "$ref": "#/$defs/VendorProfile" }
    },

    "payment_profiles": {
      "type": "array",
      "description": "Zahlungsarten und ihre Erkennungsmerkmale. Optionaler Bereich, in Version 1.0 locker modelliert.",
      "items": { "$ref": "#/$defs/PaymentProfile" }
    },

    "business_context_profiles": {
      "type": "array",
      "description": "Geschäftskontexte (z. B. SOMAA Event Production). Optionaler Bereich, in Version 1.0 locker modelliert.",
      "items": { "$ref": "#/$defs/BusinessContextProfile" }
    },

    "classification_profile": {
      "$ref": "#/$defs/ClassificationProfile",
      "description": "Keywords zur Klassifikation (Rechnung vs. Dokument). Optionaler Bereich."
    }

  },

  "$defs": {

    "CategoryId": {
      "type": "string",
      "enum": ["ai", "ep", "private", "unklar"],
      "description": "Bekannte Kategorien-IDs."
    },

    "FolderName": {
      "type": "string",
      "minLength": 1,
      "not": { "const": "privat" },
      "description": "Ordnername. 'privat' (ohne e) ist nicht erlaubt – korrekt ist 'private'."
    },

    "MatchingMode": {
      "type": "string",
      "enum": ["strict", "normal", "tolerant"],
      "description": "Fuzzy-Matching-Modus: strict = exakt, normal = Standard (Threshold 0.84), tolerant = locker."
    },

    "AppliesToEnum": {
      "type": "string",
      "enum": ["recipient", "sender", "any"],
      "description": "Auf welchen Adressteil sich das Profil bezieht."
    },

    "StringList": {
      "type": "array",
      "items": { "type": "string" },
      "default": []
    },

    "Category": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/CategoryId" },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Nutzerfreundlicher Anzeigename der Kategorie."
        },
        "description": {
          "type": "string",
          "description": "Optionale Erläuterung für UI-Tooltips."
        }
      }
    },

    "Folder": {
      "type": "object",
      "required": ["id", "label", "folder_name"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "enum": ["ai", "ep", "private", "unklar", "amex"],
          "description": "Logische ID des Zielordners."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Nutzerfreundlicher Anzeigename."
        },
        "folder_name": { "$ref": "#/$defs/FolderName" }
      }
    },

    "AccountCardProfile": {
      "type": "object",
      "required": ["id", "label"],
      "additionalProperties": false,
      "description": "Verbindet eine Karte, IBAN oder Anbieter mit einem Buchungskonto und einer Kategorie.",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Eindeutige ID dieses Profils."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Nutzerfreundlicher Name, z. B. 'Voba AI-Konto'."
        },
        "category": { "$ref": "#/$defs/CategoryId" },
        "payment_field": {
          "type": "string",
          "minLength": 1,
          "description": "Internes Zahlungsfeld, z. B. 'vobaai', 'amex', 'private'."
        },
        "target_folder": {
          "type": "string",
          "enum": ["ai", "ep", "private", "unklar", "amex"],
          "description": "Zielordner für Rechnungen dieses Kontos."
        },
        "card_endings": {
          "type": "array",
          "items": { "type": "string", "pattern": "^\\d{4}$" },
          "description": "Letzte 4 Ziffern bekannter Kartennummern.",
          "default": []
        },
        "apple_pay_endings": {
          "type": "array",
          "items": { "type": "string", "pattern": "^\\d{4}$" },
          "description": "Letzte 4 Ziffern bekannter Apple-Pay-Tokens.",
          "default": []
        },
        "iban_endings": {
          "type": "array",
          "items": { "type": "string", "pattern": "^\\d{4}$" },
          "description": "Letzte 4 Ziffern bekannter IBANs.",
          "default": []
        },
        "provider_hints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Anbieterhinweise im Rechnungstext, z. B. 'volksbank remseck'.",
          "default": []
        },
        "assignment_hints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optionale Hinweise zur manuellen Zuweisung, z. B. 'ai', 'ep'.",
          "default": []
        },
        "enabled": {
          "type": "boolean",
          "default": true,
          "description": "Ob dieses Profil aktiv verwendet wird."
        }
      }
    },

    "CanonicalAddress": {
      "type": "object",
      "required": ["street"],
      "additionalProperties": false,
      "properties": {
        "street": {
          "type": "string",
          "minLength": 1,
          "description": "Straßenname in Normalschreibweise."
        },
        "house_number": {
          "type": ["string", "null"],
          "description": "Hausnummer, optional."
        },
        "postal_code": {
          "type": ["string", "null"],
          "description": "Postleitzahl, optional."
        },
        "city": {
          "type": ["string", "null"],
          "description": "Stadt, optional."
        }
      }
    },

    "AddressProfile": {
      "type": "object",
      "required": ["id", "label", "category", "canonical_address"],
      "additionalProperties": false,
      "description": "Ordnet eine physische Adresse einer Kategorie zu. Varianten werden automatisch generiert.",
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "description": "Eindeutige ID dieses Adressprofils."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Nutzerfreundlicher Name, z. B. 'Rötestraße – Privat'."
        },
        "category": { "$ref": "#/$defs/CategoryId" },
        "canonical_address": { "$ref": "#/$defs/CanonicalAddress" },
        "applies_to": { "$ref": "#/$defs/AppliesToEnum" },
        "exclude_if_text_contains": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Wenn einer dieser Begriffe im Text vorkommt, wird das Profil nicht angewendet.",
          "default": []
        },
        "matching_mode": { "$ref": "#/$defs/MatchingMode" },
        "advanced_variants": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optionale manuelle Zusatzvarianten. Normalerweise leer – Compiler generiert Varianten automatisch."
        },
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    },

    "NamingField": {
      "type": "object",
      "required": ["key", "label", "enabled"],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1,
          "description": "Technischer Schlüssel des Feldes, z. B. 'invoice_date', 'art', 'supplier'."
        },
        "label": {
          "type": "string",
          "minLength": 1,
          "description": "Nutzerfreundlicher Anzeigename des Feldes."
        },
        "enabled": {
          "type": "boolean",
          "description": "Ob dieses Feld im Dateinamen enthalten ist."
        }
      }
    },

    "NamingProfile": {
      "type": "object",
      "required": ["separator", "max_length", "fields", "fallback_values"],
      "additionalProperties": false,
      "properties": {
        "separator": {
          "type": "string",
          "description": "Trennzeichen zwischen Feldern im Dateinamen.",
          "examples": ["_", "-"]
        },
        "max_length": {
          "type": "integer",
          "minimum": 10,
          "description": "Maximale Länge des generierten Dateinamens."
        },
        "fields": {
          "type": "array",
          "items": { "$ref": "#/$defs/NamingField" },
          "minItems": 1,
          "description": "Geordnete Liste der Dateinamenfelder."
        },
        "fallback_values": {
          "type": "object",
          "description": "Fallback-Werte, wenn ein Feld nicht extrahiert werden konnte.",
          "additionalProperties": { "type": ["string", "null"] }
        }
      }
    },

    "ReviewPolicy": {
      "type": "object",
      "required": ["unclear_folder", "business_unclear_payment_goes_to_unclear", "private_unclear_attributes_stay_private"],
      "additionalProperties": false,
      "properties": {
        "unclear_folder": {
          "type": "string",
          "minLength": 1,
          "description": "Zielordner für unklar klassifizierte Dokumente."
        },
        "business_unclear_payment_goes_to_unclear": {
          "type": "boolean",
          "description": "Wenn true: Geschäftsdokumente mit unklarem Zahlungsfeld landen im Unklar-Ordner."
        },
        "private_unclear_attributes_stay_private": {
          "type": "boolean",
          "description": "Wenn true: Private Dokumente bleiben im Private-Ordner, auch wenn Zahlungsfeld unklar ist."
        },
        "require_user_review_for_unclear": {
          "type": "boolean",
          "default": false,
          "description": "Wenn true: Unklar-Dokumente werden für manuelle Prüfung markiert."
        },
        "review_flags_enabled": {
          "type": "boolean",
          "default": true,
          "description": "Ob Review-Flags in Traces und Reports ausgegeben werden."
        }
      }
    },

    "VendorProfile": {
      "type": "object",
      "required": ["id", "label"],
      "description": "Bekannter Lieferant mit Zahlungszuordnung. Version 1.0: Grundstruktur.",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "recognition_hints": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Suchbegriffe für diesen Lieferanten im Rechnungstext."
        },
        "payment_field": {
          "type": "string",
          "description": "Zahlungsfeld, das diesem Lieferanten zugewiesen wird."
        },
        "category": { "$ref": "#/$defs/CategoryId" },
        "enabled": { "type": "boolean", "default": true }
      }
    },

    "PaymentProfile": {
      "type": "object",
      "required": ["id", "label"],
      "description": "Zahlungsart und ihre Erkennungsmerkmale. Version 1.0: Grundstruktur.",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Erkennungsbegriffe im Rechnungstext."
        },
        "payment_method": {
          "type": "string",
          "description": "Interne Zahlungsmethode, z. B. 'amex', 'transfer', 'card'."
        },
        "is_explicit": {
          "type": "boolean",
          "default": true,
          "description": "Wenn true: Zahlungsart ist eindeutig erkennbar (nicht nur Hinweis)."
        },
        "enabled": { "type": "boolean", "default": true }
      }
    },

    "BusinessContextProfile": {
      "type": "object",
      "required": ["id", "label", "category"],
      "description": "Geschäftskontext, z. B. SOMAA Event Production. Version 1.0: Grundstruktur.",
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "required_keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Alle diese Begriffe müssen im Text vorkommen."
        },
        "optional_keywords": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Mindestens einer dieser Begriffe muss im Text vorkommen."
        },
        "category": { "$ref": "#/$defs/CategoryId" },
        "enabled": { "type": "boolean", "default": true }
      }
    },

    "ClassificationProfile": {
      "type": "object",
      "description": "Keywords zur Unterscheidung von Rechnungen und Dokumenten. Version 1.0: Grundstruktur.",
      "properties": {
        "invoice_keywords": { "$ref": "#/$defs/StringList" },
        "document_keywords": { "$ref": "#/$defs/StringList" },
        "internal_invoice_keywords": { "$ref": "#/$defs/StringList" }
      }
    }

  }
}
